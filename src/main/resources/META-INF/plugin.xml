<!-- Plugin Configuration File: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <!-- Unique identifier of the plugin. It should be FQN, cannot be changed between the plugin versions. -->
    <id>dev.leonxia.ai-file-ref</id>

    <!-- Public plugin name should be written in Title Case.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/best-practices-for-listing.html#plugin-name -->
    <name>Ai-file-ref</name>

    <!-- A displayed Vendor name or Organization ID displayed on the Plugins Page. -->
    <vendor url="https://www.yourcompany.com">YourCompany</vendor>

    <!-- Description of the plugin displayed on the Plugin Page and IDE Plugin Manager.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/best-practices-for-listing.html#plugin-description -->
    <description><![CDATA[
        Enter short description for your plugin here.<br>
        <em>most HTML tags may be used</em>
    ]]></description>

    <!-- Product and plugin compatibility requirements.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html -->
    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.compose</depends>

    <resource-bundle>messages.FileRefMessageBundle</resource-bundle>
    <!-- Extensions defined by the plugin.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-extension-points.html -->
    <extensions defaultExtensionNs="com.intellij">
        <toolWindow id="FileRefToolWindow" factoryClass="dev.leonxia.aifileref.FileRefToolWindowFactory"
                    icon="AllIcons.Toolwindows.ToolWindowPalette"/>
        
        <notificationGroup id="FileRef.Notification"
                           displayType="BALLOON"
                           key="notification.group.name"
                           bundle="messages.FileRefMessageBundle"/>
    </extensions>

    <actions>
        <action id="dev.leonxia.aifileref.CopyFileInfoAction"
                class="dev.leonxia.aifileref.CopyFileInfoAction"
                text="复制文件信息"
                description="复制所选代码所在文件的信息"
                icon="AllIcons.Actions.Copy">
            <add-to-group group-id="Floating.CodeToolbar" anchor="last"/>
        </action>

        <action id="dev.leonxia.aifileref.FileLineSelectInfoAction"
                class="dev.leonxia.aifileref.FileLineSelectInfoAction"
                text="复制选中行文件信息"
                description="复制当前文件信息及选中的行号"
                icon="AllIcons.Actions.Copy">
            <add-to-group group-id="Floating.CodeToolbar" anchor="last"/>
            <!-- 绑定到编辑器右键菜单 -->
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>